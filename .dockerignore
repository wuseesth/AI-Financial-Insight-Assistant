# ============================================================
# .dockerignore — 减少构建上下文大小，提升构建速度
# ============================================================

# ── 版本控制 ──
.git
.gitignore

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# ── IDE / 编辑器 ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── 操作系统 ──
.DS_Store
Thumbs.db

# ── 日志 / 临时文件 ──
*.log
*.tmp
test_*.txt
test_*.py

# ── 环境变量（敏感信息，不打包进镜像） ──
.env
.env.*
